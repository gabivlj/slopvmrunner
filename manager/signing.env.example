# Copy this file to manager/.env.local (ignored by git) and set values.
# Use: security find-identity -v -p codesigning

CODESIGN_IDENTITY_SHA=""
CODESIGN_IDENTITY="Apple Development: Your Name (TEAMID)"
# Default is virtualization-only entitlements (works with NAT mode).
# For bridged mode, point to manager/vmmanager.networking.entitlements.
VMMANAGER_ENTITLEMENTS="manager/vmmanager.entitlements"
